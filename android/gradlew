#!/bin/sh

# Gradle Wrapper Script for VisitorRecord Android Project

# Find Java
if [ -n "$JAVA_HOME" ]; then
    JAVA="$JAVA_HOME/bin/java"
else
    JAVA="java"
fi

if ! command -v "$JAVA" >/dev/null 2>&1; then
    echo "Error: Java is not installed or not in PATH"
    exit 1
fi

# Check ANDROID_HOME
if [ -z "$ANDROID_HOME" ]; then
    echo "Error: ANDROID_HOME is not set"
    echo "Please set ANDROID_HOME to your Android SDK location"
    exit 1
fi

# Find Gradle
GRADLE_CMD=""
if command -v gradle >/dev/null 2>&1; then
    GRADLE_CMD="gradle"
elif [ -f "$ANDROID_HOME/bin/gradle" ]; then
    GRADLE_CMD="$ANDROID_HOME/bin/gradle"
else
    echo "Error: Gradle is not installed"
    echo "Please install Gradle or use Android Studio"
    exit 1
fi

# Execute Gradle
exec "$GRADLE_CMD" "$@"
